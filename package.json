{
  "name": "privacyguard",
  "version": "0.1.0",
  "description": "Security, privacy, and DLP control plane for OpenClaw subagents",
  "type": "module",
  "main": "dist/data-model/index.js",
  "types": "dist/data-model/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "audit:deps": "npm audit --audit-level=moderate",
    "check": "npm run typecheck && npm run lint && npm run test && npm run audit:deps"
  },
  "dependencies": {
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^4.0.18"
  }
}
